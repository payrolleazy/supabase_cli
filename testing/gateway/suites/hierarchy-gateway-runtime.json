                                       "Authorization":  "Bearer {{SUPABASE_ANON_KEY}}"
                                   },
                       "body":  {
                                    "email":  "hierarchy.{{RUN_ID}}@example.test",
                                    "password":  "GatewayPass@12345",
                                    "data":  {
                                                 "full_name":  "Hierarchy Certification User {{RUN_ID}}"
                                             }
                                },
